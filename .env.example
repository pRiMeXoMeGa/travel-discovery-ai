# ─────────────────────────────────────────────────────────────────────────────
# Travel Discovery AI — environment template. Copy to `.env` and fill in.
# Local dev defaults point at the docker-compose services. The commented
# values show the Path A free-tier cloud targets (Neon / Qdrant Cloud / Upstash).
# ─────────────────────────────────────────────────────────────────────────────

# ── Relational store: Postgres (local: docker `postgres` service) ────────────
# Holds all 50K listings + all 200K reviews (relational). asyncpg DSN.
DATABASE_URL=postgresql://travel:travel@postgres:5432/travel
# Prod (Neon): postgresql://USER:PASSWORD@ep-xxx.region.aws.neon.tech/travel?sslmode=require

# ── Vector store: Qdrant (local: docker `qdrant` service) ────────────────────
# Holds all 250K embeddings @ 384-dim (50K listings + 200K reviews).
QDRANT_URL=http://qdrant:6333
QDRANT_API_KEY=
QDRANT_COLLECTION_LISTINGS=listings
QDRANT_COLLECTION_REVIEWS=reviews
# Prod (Qdrant Cloud free 1GB): QDRANT_URL=https://xxx.cloud.qdrant.io  + QDRANT_API_KEY=...

# ── Cache: Redis (local: docker `redis` service) ─────────────────────────────
REDIS_URL=redis://redis:6379/0
CACHE_TTL_SECONDS=3600
# Prod (Upstash): rediss://default:PASSWORD@xxx.upstash.io:6379

# ── LLM provider ─────────────────────────────────────────────────────────────
# "gemini" (free tier, default) or "anthropic" (paid fallback).
LLM_PROVIDER=gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# ── Embeddings (local, free — fastembed/ONNX, no torch) ──────────────────────
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
EMBEDDING_DIM=384

# ── App ──────────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000
# Prod: CORS_ORIGINS=https://your-app.vercel.app

# ── Frontend (Next.js) ───────────────────────────────────────────────────────
# Set in frontend/.env.local or Vercel project settings.
NEXT_PUBLIC_API_URL=http://localhost:8000
